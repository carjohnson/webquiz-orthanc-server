{
  "Name": "Orthanc",
  "AuthenticationEnabled": true,
  "RegisteredUsers": {
    "test": "test"
  },
  "RemoteAccessAllowed": true,
  "HttpServerEnabled": true,

  "Plugins": [
    "/usr/local/share/orthanc/plugins/libOrthancDicomWeb.so"
  ],

  "ExtraHeaders": {
    "Access-Control-Allow-Origin": "*"
  },

  "DicomWeb": {
    "Enable": true,
    "Root": "/dicom-web",
    "EnableWado": true,
    "EnableQido": true,
    "EnableStow": true
  }
}
