{
  "Name": "Orthanc",
  "AuthenticationEnabled": true,
  "RegisteredUsers": {
    "test": "test"
  },
  "RemoteAccessAllowed": true,
  "HttpServerEnabled": true,
  "HttpHeaders" : {
    "Access-Control-Allow-Origin" : "*"
  },
  "Plugins": [
    "/usr/local/share/orthanc/plugins/libOrthancDicomWeb.so"
  ],


  "DicomWeb": {
    "Enable": true,
    "Root": "/dicom-web",
    "EnableWado": true,
    "EnableQido": true,
    "EnableStow": true
  }
}
