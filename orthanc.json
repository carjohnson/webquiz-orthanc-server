{
  "Name": "Orthanc",
  "AuthenticationEnabled": true,
  "RemoteAccessAllowed": true,
  "HttpServerEnabled": true,
  "HttpAllowOrigin": "*",
  "HttpDescribeErrors": true,
  "TraceEnabled": true,
  "Plugins": [
    "/usr/local/share/orthanc/plugins/libOrthancDicomWeb.so"
  ],

  "DicomWeb": {
    "Enable": true,
    "Root": "/dicom-web",
    "EnableWado": true,
    "EnableQido": true,
    "EnableStow": true,
    "EnableCors": true,
    "CorsAllowedOrigin": "*"
  },
  "ExtraHeaders": {
  "X-Test-Cors": "hello-from-orthanc"
}


}
