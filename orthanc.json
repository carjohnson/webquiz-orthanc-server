{
  "Name": "Orthanc on Render",
  "AuthenticationEnabled": true,
  "RegisteredUsers": {
    "${ORTHANC_USER}": "${ORTHANC_PASSWORD}"
  },
  "RemoteAccessAllowed": true,

  "StorageDirectory": "/var/lib/orthanc/db",

  "DicomServerEnabled": false,
  "HttpServerEnabled": true,
  "HttpPort": 8042,
  "HttpDescribeErrors": true,
  "HttpAllowOrigin": "*",
  "Plugins": [
    "/usr/local/share/orthanc/plugins/libOrthancDicomWeb.so"
  ],

  "DicomWeb": {
    "Enable": true,
    "Root": "/dicom-web/",
    "EnableWado": true,
    "EnableQido": true,
    "EnableStow": true
  }
}